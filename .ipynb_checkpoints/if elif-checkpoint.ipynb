   "source": [
    "#check type of triangle\n",
    "a=int(input())\n",
    "b=int(input())\n",
    "c=int(input())\n",
    "if a+b>c and a+c>b and b+c>a:\n",
    "    if a==b==c:\n",
    "        print(\"equilateral\")\n",
    "    elif a==b or b==c or a==c:\n",
    "        print(\"isosceles\")\n",
    "    else:\n",
    "        print(\"scalene\")\n",
    "print(\"not valid triangle\")        "
   ]
  }
